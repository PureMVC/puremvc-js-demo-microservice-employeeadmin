### Save
POST http://localhost/graphql
Content-Type: application/json
Accept: application/json

{
  "query": "mutation Save($username: String!, $first: String!, $last: String!, $email: String!, $password: String!, $department: IDepartment!, $roles: [IRole!]) { save(username: $username, first: $first, last: $last, email: $email, password: $password, department: $department, roles: $roles) { id username first last email department { id name } roles { id name } } }",
  "variables": {
    "username": "sshemp",
    "first": "Shemp",
    "last": "Stooge",
    "email": "sshemp@stooges.com",
    "password": "ghi123",
    "department": {
      "id": "2",
      "name": "Sales"
    },
    "roles": [
      {
        "id": "2",
        "name": "Accounts Payable"
      }
    ]
  }
}

### Update
POST http://localhost/graphql
Content-Type: application/json
Accept: application/json

{
  "query": "mutation Update($id: ID!, $username: String!, $first: String!, $last: String!, $email: String!, $password: String!, $department: IDepartment!, $roles: [IRole!]) { update(id: $id, username: $username, first: $first, last: $last, email: $email, password: $password, department: $department, roles: $roles) { id username first last email department { id name } roles { id name } } }",
  "variables": {
    "id": 4,
    "username": "sshemp",
    "first": "Shemp",
    "last": "Stooge",
    "email": "sshemp@stooges.com",
    "password": "ghi123",
    "department": {
      "id": "2",
      "name": "Sales"
    },
    "roles": [
      {
        "id": "1",
        "name": "Administrator"
      }
    ]
  }
}

### UpdateRolesByUserId
POST http://localhost/graphql
Content-Type: application/json
Accept: application/json

{
  "query": "mutation UpdateRolesByUserId($id: ID!, $roles: [IRole!]!) { updateRolesByUserId(id: $id, roles: $roles) }",
  "variables": {
    "id": 4,
    "roles": [
      {
        "id": "1",
        "name": "Administrator"
      },
      {
        "id": "2",
        "name": "Accounts Payable"
      }
    ]
  }
}

### DeleteById
POST http://localhost/graphql
Content-Type: application/json
Accept: application/json

{
  "query": "mutation DeleteById($id: ID!) { deleteById(id: $id) }",
  "variables": {
    "id": 4
  }
}